% =============================================================================
%  mobi-lectura.sty — Estilo unificado para lecturas del curso MoBI
%  Modelado de Sistemas bajo Incertidumbre · Uniandes · Ingeniería Industrial
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mobi-lectura}[2026/01/01 MoBI Lecture Style]

% ── Codificación e idioma ────────────────────────────────────────────────────
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[spanish, es-tabla, es-noshorthands]{babel}

% ── Matemáticas ──────────────────────────────────────────────────────────────
\usepackage{amsmath, amssymb, amsthm, mathtools, bm}

% ── Geometría y tipografía ───────────────────────────────────────────────────
\usepackage[left=2.5cm, right=2.5cm, top=3cm, bottom=3cm, headheight=22pt]{geometry}
\usepackage{setspace}
\setstretch{1.2}
\usepackage{parskip}
\setlength{\parskip}{5pt plus 1pt}

% ── Gráficos ─────────────────────────────────────────────────────────────────
\usepackage{graphicx}
\usepackage{float}
\usepackage{tikz}
\usetikzlibrary{arrows.meta, positioning, calc, shapes.geometric,
                automata, decorations.pathreplacing, babel}
\usepackage{pgfplots}
\pgfplotsset{compat=1.18}

% ── Tablas ───────────────────────────────────────────────────────────────────
\usepackage{booktabs, array, tabularx, multirow, colortbl, siunitx}

% ── Listas ───────────────────────────────────────────────────────────────────
\usepackage{enumitem}
\setlist[itemize]{leftmargin=1.5em, itemsep=3pt, topsep=3pt}
\setlist[enumerate]{leftmargin=1.5em, itemsep=3pt, topsep=3pt}

% ── Colores y cajas ──────────────────────────────────────────────────────────
\usepackage{xcolor}
\usepackage[most, breakable]{tcolorbox}

% ── Encabezados y pies ───────────────────────────────────────────────────────
\usepackage{fancyhdr}
\usepackage{titlesec}

% ── Hipervínculos ────────────────────────────────────────────────────────────
\usepackage{hyperref}

% =============================================================================
%  PALETA DE COLORES MoBI
% =============================================================================
\definecolor{mobiblue}{RGB}{0,71,133}
\definecolor{mobigold}{RGB}{200,160,40}
\definecolor{mobidark}{RGB}{0,40,85}
\definecolor{mobilightblue}{RGB}{220,235,250}
\definecolor{mobilightgold}{RGB}{255,245,200}
\definecolor{mobilightred}{RGB}{255,225,225}
\definecolor{mobilightgreen}{RGB}{220,245,220}
\definecolor{mobisoftgray}{RGB}{245,245,247}
\definecolor{mobigray}{RGB}{127,140,141}
% ── Alias de compatibilidad con archivos anteriores ──────────────────────────
\colorlet{uniblue}{mobiblue}
\colorlet{uniandes}{mobiblue}
\colorlet{unigold}{mobigold}
\colorlet{darkgreen}{green!50!black}
\definecolor{rojoclaro}{RGB}{204,51,51}
\definecolor{verdeoscuro}{RGB}{0,102,51}
\definecolor{naranja}{RGB}{230,126,34}
\definecolor{grisclaro}{RGB}{236,240,241}

% =============================================================================
%  FORMATO DE SECCIONES
% =============================================================================
\titleformat{\section}
  {\large\bfseries\color{mobiblue}}
  {\thesection.}{0.5em}{}
  [{\color{mobiblue}\titlerule[0.8pt]}]
\titleformat{\subsection}
  {\normalsize\bfseries\color{mobiblue!80!black}}
  {\thesubsection.}{0.5em}{}
\titleformat{\subsubsection}
  {\normalsize\itshape\color{mobiblue!60!black}}
  {\thesubsubsection.}{0.5em}{}
\titlespacing*{\section}{0pt}{14pt}{6pt}
\titlespacing*{\subsection}{0pt}{10pt}{4pt}
\titlespacing*{\subsubsection}{0pt}{8pt}{3pt}

% =============================================================================
%  ENCABEZADO Y PIE DE PÁGINA
% =============================================================================
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\color{mobiblue}\textit{Modelado de Sistemas bajo Incertidumbre}}
\fancyhead[R]{\small\color{mobiblue}\nouppercase{\leftmark}}
\fancyfoot[C]{\small\color{mobiblue!70}\thepage}
\renewcommand{\headrulewidth}{0.6pt}
\renewcommand{\headrule}{%
  \hbox to\headwidth{\color{mobiblue}\leaders\hrule height\headrulewidth\hfill}}

% =============================================================================
%  ENTORNOS MATEMÁTICOS
% =============================================================================
\theoremstyle{definition}
\newtheorem{definicion}{Definición}[section]
\newtheorem{ejemplo}{Ejemplo}[section]
\newtheorem{propiedad}{Propiedad}[section]
\newtheorem{teorema}{Teorema}[section]
\newtheorem{corolario}{Corolario}[section]
\theoremstyle{remark}
\newtheorem{nota}{Nota}[section]

% =============================================================================
%  CAJAS TCOLORBOX
%  Argumento único opcional: título de la caja (por defecto = tipo de caja)
% =============================================================================

% Definición (azul institucional)
\newtcolorbox{definicionbox}[1][Definición]{
  enhanced, breakable,
  colback=mobilightblue, colframe=mobiblue,
  colbacktitle=mobiblue, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=3pt, boxrule=0pt, leftrule=4pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt,
  shadow={1mm}{-1mm}{0mm}{black!10}
}

% Ejemplo (verde)
\newtcolorbox{ejemplobox}[1][Ejemplo]{
  enhanced, breakable,
  colback=mobilightgreen, colframe=mobiblue!55!black,
  colbacktitle=mobiblue!55!black, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=3pt, boxrule=0pt, leftrule=4pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt,
  shadow={1mm}{-1mm}{0mm}{black!10}
}

% Alerta / advertencia (rojo)
\newtcolorbox{alertabox}[1][Atención]{
  enhanced, breakable,
  colback=mobilightred, colframe=red!70!black,
  colbacktitle=red!70!black, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=3pt, boxrule=0pt, leftrule=4pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt
}

% Nota / observación (dorado)
\newtcolorbox{notabox}[1][Nota]{
  enhanced, breakable,
  colback=mobilightgold, colframe=mobigold,
  colbacktitle=mobigold, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=3pt, boxrule=0pt, leftrule=4pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt
}

% Método / procedimiento (azul oscuro)
\newtcolorbox{metodobox}[1][Método]{
  enhanced, breakable,
  colback=mobiblue!5, colframe=mobiblue,
  colbacktitle=mobiblue, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=2pt, boxrule=0.8pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt
}

% Resultado (gris claro)
\newtcolorbox{resultadobox}[1][Resultado]{
  enhanced, breakable,
  colback=mobisoftgray, colframe=mobidark,
  colbacktitle=mobidark, coltitle=white,
  fonttitle=\bfseries\small,
  title={#1},
  arc=3pt, boxrule=0pt, leftrule=4pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt
}

% =============================================================================
%  COMANDOS MATEMÁTICOS
% =============================================================================
\newcommand{\E}{\mathbb{E}}
\newcommand{\Var}{\operatorname{Var}}
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\providecommand{\1}{\mathbf{1}}
% Macros específicos del curso
\newcommand{\mat}[1]{\mathbf{#1}}           % Matriz en negrita: \mat{Q}
\newcommand{\ind}[1]{\mathbf{1}_{[#1]}}     % Función indicadora: \ind{n\ge1}
\newcommand{\FEL}{\texttt{FEL}}             % Future Event List
\newcommand{\vect}[1]{\boldsymbol{#1}}      % Vector en negrita: \vect{v}

% =============================================================================
%  PORTADA UNIFICADA (invocada con \maketitle)
%  Redefinimos \maketitle para mostrar cabecera institucional + título
% =============================================================================
\renewcommand{\maketitle}{%
  \thispagestyle{empty}%
  \begin{center}
    {\color{mobiblue}\rule{\textwidth}{1.5pt}}\\[0.5em]
    {\large\bfseries\color{mobiblue} Universidad de los Andes}\\[0.15em]
    {\small Departamento de Ingeniería Industrial
      \,·\, Modelado de Sistemas bajo Incertidumbre}\\[0.6em]
    {\color{mobiblue}\rule{\textwidth}{0.6pt}}\\[1em]
    {\LARGE\bfseries\color{mobidark} \@title}\\[0.6em]
    {\normalsize\color{mobigray} \@author}\\[0.3em]
    {\color{mobiblue}\rule{\textwidth}{1.5pt}}
  \end{center}
  \vspace{1em}%
  \setcounter{page}{1}%
}

\endinput
