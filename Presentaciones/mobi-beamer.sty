% =============================================================================
%  TEMA BEAMER PERSONALIZADO
% =============================================================================
\usetheme{default}
\usecolortheme{default}

\setbeamercolor{structure}{fg=mobiblue}
\setbeamercolor{frametitle}{fg=white, bg=mobiblue}
\setbeamercolor{frametitle right}{bg=mobidark}
\setbeamercolor{title}{fg=white, bg=mobidark}
\setbeamercolor{subtitle}{fg=mobigold}
\setbeamercolor{author in title page}{fg=white}
\setbeamercolor{institute in title page}{fg=mobilightblue}
\setbeamercolor{date in title page}{fg=mobilightgold}

\setbeamercolor{block title}{fg=white, bg=mobiblue}
\setbeamercolor{block body}{bg=mobilightblue}
\setbeamercolor{block title alerted}{fg=white, bg=princetonorange}
\setbeamercolor{block body alerted}{bg=mobilightgold}
\setbeamercolor{block title example}{fg=white, bg=mobiblue!55!black}
\setbeamercolor{block body example}{bg=mobilightgreen}

\setbeamercolor{itemize item}{fg=mobiblue}
\setbeamercolor{itemize subitem}{fg=mobigold}
\setbeamercolor{itemize subsubitem}{fg=mobiblue!60}
\setbeamercolor{enumerate item}{fg=mobiblue}
\setbeamercolor{enumerate subitem}{fg=mobigold}

\setbeamercolor{footline}{fg=mobiblue!80, bg=mobiblue!6}
\setbeamercolor{headline}{bg=mobiblue!8}

\setbeamerfont{frametitle}{series=\bfseries, size=\normalsize}
\setbeamerfont{title}{series=\bfseries, size=\large}
\setbeamerfont{subtitle}{series=\mdseries, size=\small}
\setbeamerfont{author}{size=\small}
\setbeamerfont{institute}{size=\footnotesize}
\setbeamerfont{footline}{size=\tiny}

\setbeamertemplate{itemize items}[circle]
\setbeamertemplate{enumerate items}[default]
\setbeamertemplate{navigation symbols}{}

% Frametitle con línea inferior de color dorado
\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,ht=2.4ex,dp=0.8ex,leftskip=1em]{frametitle}%
    \usebeamerfont{frametitle}\insertframetitle%
    \ifx\insertframesubtitle\@empty\else%
      \;{\usebeamerfont{framesubtitle}\color{mobilightblue}— \insertframesubtitle}%
    \fi%
  \end{beamercolorbox}%
  \nointerlineskip%
  {\color{mobigold}\rule{\paperwidth}{1.2pt}}%
}

% Pie de página: autor | título | número de slide
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=.32\paperwidth,ht=2.4ex,dp=1ex,left]{footline}%
      \hspace*{2ex}\textit{A.~Tabares Pozos}%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.46\paperwidth,ht=2.4ex,dp=1ex,center]{footline}%
      \insertshorttitle%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=.22\paperwidth,ht=2.4ex,dp=1ex,right]{footline}%
      \insertframenumber\,/\,\inserttotalframenumber\hspace*{2ex}%
    \end{beamercolorbox}%
  }%
  \vskip0pt%
}

% Página de título
\setbeamertemplate{title page}{%
  \vbox{}%
  \vfill%
  \begin{beamercolorbox}[wd=\textwidth, sep=12pt, center]{title}%
    \usebeamerfont{title}\inserttitle\par%
    \ifx\insertsubtitle\@empty\else%
      \vskip0.4em%
      {\usebeamerfont{subtitle}\color{mobigold}\insertsubtitle\par}%
    \fi%
  \end{beamercolorbox}%
  \vskip0.5em%
  \begin{beamercolorbox}[wd=\textwidth, sep=6pt, center]{author}%
    {\usebeamerfont{author}\color{mobidark}\insertauthor}\\[0.3em]%
    {\usebeamerfont{institute}\color{mobiblue!70}\insertinstitute}\\[0.3em]%
    {\usebeamerfont{date}\color{mobiblue!60}\small\insertdate}%
  \end{beamercolorbox}%
  \vfill%
  {\color{mobigold}\rule{\textwidth}{1.5pt}}%
}

% Listas con íconos de color
\setlist[itemize,1]{label={\color{mobiblue}$\blacktriangleright$},
                    leftmargin=1.2em, itemsep=3pt}
\setlist[itemize,2]{label={\color{mobigold}$\bullet$},
                    leftmargin=1.6em, itemsep=2pt}

% =============================================================================
%  CAJAS TCOLORBOX (compatibles con todas las presentaciones)
%  Argumento único opcional: título de la caja (por defecto = tipo de caja)
% =============================================================================

\newtcolorbox{definicionbox}[1][Definición]{
  colback=mobilightblue, colframe=mobiblue,
  colbacktitle=mobiblue, coltitle=white,
  fonttitle=\bfseries\small, title={#1},
  boxrule=1pt, arc=3pt, left=6pt, right=6pt, top=4pt, bottom=4pt
}
\newtcolorbox{ejemplobox}[1][Ejemplo]{
  colback=mobilightgreen, colframe=deepgreen!80,
  colbacktitle=deepgreen!80, coltitle=white,
  fonttitle=\bfseries\small, title={#1},
  boxrule=1pt, arc=3pt, left=6pt, right=6pt, top=4pt, bottom=4pt
}
